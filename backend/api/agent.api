syntax = "v1"

info (
	title:       "Atask"
	description: "Atask-api"
	version:     "v1"
)

type (
	CreateSessionRequest {
		ProjectPath string `json:"project_path"`
		Model       string `json:"model,optional"`
	}
	SessionResponse {
		ID          string `json:"id"`
		ProjectPath string `json:"project_path"`
		Model       string `json:"model"`
		State       string `json:"state"`
		CreatedAt   string `json:"created_at"`
		BlockedOn   string `json:"blocked_on,optional"`
		BlockedTool string `json:"blocked_tool,optional"`
	}
	SessionListRequest {
		ProjectPath string `form:"project_path,optional"`
	}
	SessionListResponse {
		Sessions []SessionResponse `json:"sessions"`
	}
	GetSessionRequest {
		ID string `path:"id"`
	}
	SubmitInputRequest {
		ID    string `path:"id"`
		Input string `json:"input"`
		Mode  string `json:"mode,optional"`
	}
	ApprovePlanRequest {
		ID string `path:"id"`
	}
	UnblockRequest {
		ID         string `path:"id"`
		Response   string `json:"response"`
		Approved   bool   `json:"approved"`
		AddAllowed string `json:"add_allowed,optional"`
	}
	StreamSessionEventsRequest {
		ID string `path:"id"`
	}
	SessionEvent {
		Type      string                 `json:"type"`
		SessionID string                 `json:"session_id"`
		Timestamp string                 `json:"timestamp"`
		Data      map[string]interface{} `json:"data"`
	}
	ErrorResponse {
		Error string `json:"error"`
	}
	ProjectResponse {
		Path     string   `json:"path"`
		Sessions []string `json:"sessions"`
	}
	ProjectListResponse {
		Projects []ProjectResponse `json:"projects"`
	}
	CreateProjectRequest {
		Path string `json:"path"`
	}
	GetProjectRequest {
		name string `path:"name"`
	}
)

@server (
	prefix: /api
)
service agent-api {
	@handler ListProjects
	get /projects returns (ProjectListResponse)

	@handler GetProject
	get /projects/:name (GetProjectRequest) returns (ProjectResponse)

	@handler CreateProject
	post /projects (CreateProjectRequest) returns (ProjectResponse)

	@handler CreateSession
	post /sessions (CreateSessionRequest) returns (SessionResponse)

	@handler ListSessions
	get /sessions (SessionListRequest) returns (SessionListResponse)

	@handler GetSession
	get /sessions/:id (GetSessionRequest) returns (SessionResponse)

	@handler SubmitInput
	post /sessions/:id/input (SubmitInputRequest) returns (SessionResponse)

	@handler ApprovePlan
	post /sessions/:id/approve (ApprovePlanRequest) returns (SessionResponse)

	@handler UnblockSession
	post /sessions/:id/unblock (UnblockRequest) returns (SessionResponse)
}

@server (
	prefix:  /api
	sse:     true
	timeout: 1h
)
service agent-api {
	@handler StreamSessionEvents
	get /sessions/:id/events (StreamSessionEventsRequest) returns (SessionEvent)
}

